{
  "name": "tenant-hub",
  "private": true,
  "version": "0.1.0",
  "description": "轻量化公寓管理系统 monorepo",
  "scripts": {
    "dev": "pnpm --parallel --filter @tenant-hub/api --filter @tenant-hub/tenant-web dev",
    "dev:infra": "docker compose -f docker-compose.infra.yml up -d",
    "dev:all": "pnpm dev:infra && pnpm db:generate && pnpm db:migrate && pnpm dev",
    "dev:miniprogram": "pnpm --filter @tenant-hub/miniprogram dev:weapp",
    "build:miniprogram": "pnpm --filter @tenant-hub/miniprogram build:weapp",
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "dotenv -e .env -- pnpm --filter @tenant-hub/api prisma generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @tenant-hub/api prisma migrate dev",
    "prepare": "husky && pnpm db:generate",
    "release": "node scripts/release.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "conventional-changelog-cli": "^4.0.0",
    "dotenv-cli": "^11.0.0",
    "enquirer": "^2.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "semver": "^7.6.0",
    "typescript-eslint": "^8.59.2"
  }
}
