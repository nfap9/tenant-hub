# ============================================
# Tenant Hub 生产部署环境变量
# ============================================
# 使用方式：复制本文件为仓库根目录的 .env.production
# 适用：docker compose --env-file .env.production -f docker-compose.prod.yml up --build
# ============================================
# 安全提示（必读）：
#   - JWT_SECRET 必须改为 32 位以上强随机字符串
#   - POSTGRES_PASSWORD 必须改为强密码
#   - CORS_ORIGINS 必须配置为实际域名，禁止用 *
# ============================================

# PostgreSQL
POSTGRES_DB=tenant_hub
POSTGRES_USER=postgres
# 【重要】必须修改为强密码
POSTGRES_PASSWORD=changeme-strong-password

# API
DATABASE_URL="postgresql://postgres:changeme-strong-password@postgres:5432/tenant_hub?schema=public"
JWT_SECRET="your-very-strong-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"
# 单域名方案：前端与 API 共用一个域名，CORS 只需配置该域名
CORS_ORIGINS="https://www.yourdomain.com"
# 自动创建超级管理员账号（启动时若该手机号不存在则自动创建，已存在则跳过）
PLATFORM_ADMIN_PHONE=""
PLATFORM_ADMIN_PASSWORD=""
PORT=4000
OTP_EXPIRES_IN_MINUTES=5
BCRYPT_OTP_SALT_ROUNDS=10
BCRYPT_PASSWORD_SALT_ROUNDS=12
INVITE_EXPIRES_IN_HOURS=24
INVITE_EXPIRES_MAX_HOURS=168

# 运维前端（构建时注入，Vite 会将此地址打包进静态资源）
# 单域名方案：API 通过 /api/ 路径代理，末尾不要加斜杠
VITE_API_BASE_URL="https://www.yourdomain.com/api"

# 移动端（修改后需重新构建 APK/IPA）
# 移动端可独立使用子域名或同域名，不影响 ops-web 的单域名部署
API_BASE_URL="https://www.yourdomain.com/api"
