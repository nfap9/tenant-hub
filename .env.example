# ============================================
# Tenant Hub 本地开发环境变量
# ============================================
# 使用方式：复制本文件为仓库根目录的 .env
# 适用：pnpm dev / docker compose -f docker-compose.dev.yml up --build
# ============================================

# PostgreSQL（Docker 开发环境）
POSTGRES_DB=tenant_hub
POSTGRES_USER=postgres
# 【重要】生成环境必须修改为强密码
POSTGRES_PASSWORD=postgres

## API
# postgresql://{user}[:{password}]@{host}:{port}/tenant_hub?schema=public
DATABASE_URL=

# TOKEN生成密钥，生产环境必须修改为长度32以上随机字符串
JWT_SECRET=
# TOEKN过期时间，exp: 1h, 7d
JWT_EXPIRES_IN=

# 允许跨域
CORS_ORIGINS=

# 自动创建超级管理员账号（启动时若该手机号不存在则自动创建，已存在则跳过）
PLATFORM_ADMIN_PHONE=
PLATFORM_ADMIN_PASSWORD=

# API服务端口
PORT=4000

# 验证码过期时间（分钟）
OTP_EXPIRES_IN_MINUTES=5
# 验证码加盐轮数
BCRYPT_OTP_SALT_ROUNDS=10
# 用户密码加盐轮数
BCRYPT_PASSWORD_SALT_ROUNDS=12
# 组织邀请默认有效期
INVITE_EXPIRES_IN_HOURS=24
# 组织邀请最大有效期，限制用户自定义邀请过期时间时不能超过的上限
INVITE_EXPIRES_MAX_HOURS=168

# 运维前端
VITE_API_BASE_URL="http://localhost:4000/api"

# 移动端 / 小程序
# Android 模拟器访问宿主机需使用 10.0.2.2，iOS 模拟器使用 localhost
# 小程序正式版构建时会将此值编译进代码，请根据部署环境修改
API_BASE_URL="http://localhost:4000/api"
