# ============================================
# Tenant Hub 本地开发环境变量
# ============================================
# 使用方式：复制本文件为仓库根目录的 .env
# 适用：pnpm dev:all（Docker 启动中间件 + pnpm 启动各服务）
# ============================================

# PostgreSQL（docker-compose.infra.yml 中的 postgres 服务）
POSTGRES_DB=tenant_hub
POSTGRES_USER=postgres
# 【重要】生产环境必须修改为强密码
POSTGRES_PASSWORD=postgres

## API
# Docker 开发环境（docker-compose.infra.yml 将 postgres 暴露到宿主机 5433 端口）
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tenant_hub?schema=public

# TOKEN生成密钥，开发环境会自动填充默认值，生产环境必须修改为长度32以上随机字符串
JWT_SECRET=tenant-hub-dev-secret
# TOKEN过期时间，示例：1h, 7d
JWT_EXPIRES_IN=7d

# 允许跨域的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5174,http://localhost:8081,http://localhost:19006

# API 服务端口
PORT=4000

# 验证码过期时间（分钟）
OTP_EXPIRES_IN_MINUTES=5
# 验证码加盐轮数
BCRYPT_OTP_SALT_ROUNDS=10
# 用户密码加盐轮数
BCRYPT_PASSWORD_SALT_ROUNDS=12
# 组织邀请默认有效期（小时）
INVITE_EXPIRES_IN_HOURS=24
# 组织邀请最大有效期（小时）
INVITE_EXPIRES_MAX_HOURS=168

# Web 前端 API Base URL
VITE_API_BASE_URL="http://localhost:4000/api"

# 小程序端
# Android 模拟器访问宿主机需使用 10.0.2.2，iOS 模拟器使用 localhost
API_BASE_URL="http://localhost:4000/api"
