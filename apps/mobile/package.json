{
  "name": "@tenant-hub/mobile",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "react-native start",
    "android": "react-native run-android",
    "preandroid": "node scripts/check-android-env.js",
    "ios": "react-native run-ios",
    "android:build:debug": "cd android && ./gradlew assembleDebug",
    "android:build:release": "cd android && ./gradlew assembleRelease",
    "android:apk": "pnpm android:build:release",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",

    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "react": "^18.3.1",
    "react-native": "^0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-vector-icons": "^10.2.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "15.1.3",
    "@react-native-community/cli-platform-android": "15.1.3",
    "@react-native-community/cli-platform-ios": "15.1.3",
    "@react-native/babel-preset": "0.76.9",
    "@react-native/gradle-plugin": "0.76.9",
    "@react-native/metro-config": "0.76.9",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.18",
    "@types/react-native-vector-icons": "^6.4.18",
    "eslint": "^9.25.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "react-native-dotenv": "^3.4.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.31.1"
  }
}
