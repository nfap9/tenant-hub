generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OtpPurpose {
  REGISTER
  LOGIN
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum RoomStatus {
  VACANT
  RESERVED
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  ACTIVE
  TERMINATED
  EXPIRED
}

enum RentCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TerminationType {
  EXPIRED
  NEGOTIATED
  BREACH
}

enum BillStatus {
  DRAFT
  BILLING
  UNPAID
  PARTIAL_PAID
  PAID
  FAILED
  VOID
}

enum BillMode {
  PREPAID
  POSTPAID
}

enum BillItemType {
  RENT
  UTILITY
  WATER
  POWER
  DEPOSIT
  MANAGEMENT
  NETWORK
  OTHER
}

enum MeterType {
  WATER
  POWER
}

enum MeterReadingSource {
  MANUAL
  IMPORT
}

enum MeterReadingStatus {
  NORMAL
  SUSPECTED
  CONFIRMED
  VOID
}

enum PlatformRole {
  NONE
  OPERATOR
  ADMIN
  SUPER_ADMIN
}

enum SettlementStatus {
  PENDING
  SETTLED
}

enum SettlementPaymentDirection {
  RECEIVE
  REFUND
}

model User {
  id           String       @id @default(cuid())
  phone        String       @unique
  username     String
  passwordHash String
  platformRole PlatformRole @default(NONE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  OrgMember[]
  payments     Payment[]
  meterReadings MeterReading[]
  createdOrgInvites OrgInvite[] @relation("OrgInviteCreatedBy")
  usedOrgInvites    OrgInvite[] @relation("OrgInviteUsedBy")
  settlementPayments SettlementPayment[]
}

model OtpCode {
  id        String     @id @default(cuid())
  phone     String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([phone, purpose])
}

model Organization {
  id            String             @id @default(cuid())
  name          String
  code          String             @unique
  description   String?
  status        OrgStatus          @default(ACTIVE)
  ownerId       String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  members       OrgMember[]
  apartments    Apartment[]
  leases        Lease[]
  bills         Bill[]
  monthlyBills  MonthlyBill[]
  meterReadings MeterReading[]
  quotas        OrgQuotaPackage[]
  subscriptions Subscription[]
  invites       OrgInvite[]
  settlements   LeaseSettlement[]
}

model Role {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String?
  system      Boolean     @default(false)
  permissions String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  members     OrgMember[]
}

model OrgMember {
  id             String        @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  status         MemberStatus  @default(ACTIVE)
  joinedAt       DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  role           Role          @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
}

model OrgInvite {
  id             String       @id @default(cuid())
  organizationId String
  code           String       @unique
  maxUses        Int          @default(1)
  usedCount      Int          @default(0)
  expiresAt      DateTime
  createdById    String
  usedById       String?
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("OrgInviteCreatedBy", fields: [createdById], references: [id])
  usedBy         User?        @relation("OrgInviteUsedBy", fields: [usedById], references: [id])

  @@index([organizationId, createdAt])
  @@index([code, expiresAt])
}

model Apartment {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  location       String
  floors         Int
  landArea       Decimal?     @db.Decimal(12, 2)
  totalArea      Decimal?     @db.Decimal(12, 2)
  landlordName   String?
  landlordPhone  String?
  contractStart  DateTime?
  contractEnd    DateTime?
  rentAmount     Decimal?     @db.Decimal(12, 2)
  waterUnitPrice  Decimal      @default(0) @db.Decimal(10, 2)
  powerUnitPrice  Decimal      @default(0) @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  rooms          Room[]
  expenses       ApartmentExpense[]
  feeItems       ApartmentFeeItem[]
  meterReadings  MeterReading[]
}

model ApartmentExpense {
  id          String    @id @default(cuid())
  apartmentId String
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  spentAt     DateTime
  note        String?
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model ApartmentFeeItem {
  id          String    @id @default(cuid())
  apartmentId String
  name        String
  spec        String?
  amount      Decimal   @db.Decimal(10, 2)
  enabled     Boolean   @default(true)
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  leaseFees   LeaseFee[]
}

model Room {
  id          String     @id @default(cuid())
  apartmentId String
  roomNo      String
  layout      String
  area        Decimal?   @db.Decimal(10, 2)
  facilities  String[]
  status      RoomStatus @default(VACANT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  apartment   Apartment  @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  leases      Lease[]
  meterReadings MeterReading[]
  settlements LeaseSettlement[]

  @@unique([apartmentId, roomNo])
}

model Lease {
  id                String           @id @default(cuid())
  organizationId    String
  roomId            String
  tenantName        String
  tenantPhone       String
  startDate         DateTime
  endDate           DateTime
  graceDays         Int              @default(0)
  cycle             RentCycle
  rentAmount        Decimal          @db.Decimal(12, 2)
  depositAmount     Decimal          @default(0) @db.Decimal(12, 2)
  waterUnitPrice     Decimal          @db.Decimal(10, 2)
  powerUnitPrice     Decimal          @db.Decimal(10, 2)
  autoRenew          Boolean          @default(false)
  status            LeaseStatus      @default(ACTIVE)
  terminationType   TerminationType?
  terminationReason String?
  terminatedAt      DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  organization      Organization     @relation(fields: [organizationId], references: [id])
  room              Room             @relation(fields: [roomId], references: [id])
  fees              LeaseFee[]
  bills             Bill[]
  monthlyBills      MonthlyBill[]
  meterReadings     MeterReading[]
  settlement        LeaseSettlement?
}

model LeaseSettlement {
  id                      String           @id @default(cuid())
  organizationId          String
  leaseId                 String           @unique
  roomId                  String
  type                    TerminationType
  reason                  String?
  terminatedAt            DateTime
  depositAmount           Decimal          @db.Decimal(12, 2)
  depositDeductionAmount  Decimal          @default(0) @db.Decimal(12, 2)
  depositDeductionReason  String?
  depositRefundAmount     Decimal          @default(0) @db.Decimal(12, 2)
  rentAdjustmentAmount    Decimal          @default(0) @db.Decimal(12, 2)
  previousWater           Decimal          @default(0) @db.Decimal(12, 2)
  currentWater            Decimal          @default(0) @db.Decimal(12, 2)
  previousPower           Decimal          @default(0) @db.Decimal(12, 2)
  currentPower            Decimal          @default(0) @db.Decimal(12, 2)
  waterUnitPrice          Decimal          @default(0) @db.Decimal(10, 2)
  powerUnitPrice          Decimal          @default(0) @db.Decimal(10, 2)
  utilityAmount           Decimal          @default(0) @db.Decimal(12, 2)
  otherFeeAmount          Decimal          @default(0) @db.Decimal(12, 2)
  otherFeeReason          String?
  receivableAmount        Decimal          @default(0) @db.Decimal(12, 2)
  refundableAmount        Decimal          @default(0) @db.Decimal(12, 2)
  netAmount               Decimal          @default(0) @db.Decimal(12, 2)
  status                  SettlementStatus @default(PENDING)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  organization            Organization     @relation(fields: [organizationId], references: [id])
  lease                   Lease            @relation(fields: [leaseId], references: [id])
  room                    Room             @relation(fields: [roomId], references: [id])
  payments                SettlementPayment[]

  @@index([organizationId, status])
  @@index([roomId, terminatedAt])
}

model SettlementPayment {
  id           String                     @id @default(cuid())
  settlementId String
  userId       String
  direction    SettlementPaymentDirection
  amount       Decimal                    @db.Decimal(12, 2)
  paidAt       DateTime                   @default(now())
  method       String
  note         String?
  settlement   LeaseSettlement            @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  user         User                       @relation(fields: [userId], references: [id])

  @@index([settlementId, paidAt])
}

model LeaseFee {
  id        String            @id @default(cuid())
  leaseId   String
  feeItemId String?
  name      String
  amount    Decimal           @db.Decimal(10, 2)
  lease     Lease             @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  feeItem   ApartmentFeeItem? @relation(fields: [feeItemId], references: [id])
}

model Bill {
  id             String       @id @default(cuid())
  organizationId String
  leaseId        String
  monthlyBillId  String?
  mode           BillMode     @default(PREPAID)
  billingDate    DateTime
  periodStart    DateTime
  periodEnd      DateTime
  dueDate        DateTime
  status         BillStatus   @default(UNPAID)
  totalAmount    Decimal      @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal      @default(0) @db.Decimal(12, 2)
  failureReason  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  lease          Lease        @relation(fields: [leaseId], references: [id])
  monthlyBill    MonthlyBill? @relation(fields: [monthlyBillId], references: [id])
  items          BillItem[]
  payments       Payment[]

  @@unique([leaseId, billingDate, mode])
  @@index([organizationId, status])
  @@index([leaseId, billingDate])
}

model BillItem {
  id             String       @id @default(cuid())
  billId         String
  type           BillItemType
  name           String
  amount         Decimal      @default(0) @db.Decimal(12, 2)
  status         BillStatus   @default(UNPAID)
  previousWater  Decimal?     @db.Decimal(12, 2)
  currentWater   Decimal?     @db.Decimal(12, 2)
  previousPower  Decimal?     @db.Decimal(12, 2)
  currentPower   Decimal?     @db.Decimal(12, 2)
  waterUnitPrice Decimal?     @db.Decimal(10, 2)
  powerUnitPrice Decimal?     @db.Decimal(10, 2)
  note           String?
  bill           Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  billId    String?
  monthlyBillId String?
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now())
  method    String
  note      String?
  bill      Bill?    @relation(fields: [billId], references: [id])
  monthlyBill MonthlyBill? @relation(fields: [monthlyBillId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model MonthlyBill {
  id             String       @id @default(cuid())
  organizationId String
  leaseId        String
  tenantName     String
  tenantPhone    String
  billingDate    DateTime
  dueDate        DateTime
  status         BillStatus   @default(UNPAID)
  totalAmount    Decimal      @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal      @default(0) @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  lease          Lease        @relation(fields: [leaseId], references: [id])
  bills          Bill[]
  payments       Payment[]

  @@unique([leaseId, billingDate])
  @@index([organizationId, status])
}

model MeterReading {
  id             String             @id @default(cuid())
  organizationId String
  apartmentId    String
  roomId         String
  leaseId        String?
  meterType      MeterType
  readingDate    DateTime
  value          Decimal            @db.Decimal(12, 2)
  source         MeterReadingSource @default(MANUAL)
  status         MeterReadingStatus @default(NORMAL)
  note           String?
  createdById    String?
  createdAt      DateTime           @default(now())
  organization   Organization       @relation(fields: [organizationId], references: [id])
  apartment      Apartment          @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  room           Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  lease          Lease?             @relation(fields: [leaseId], references: [id])
  createdBy      User?              @relation(fields: [createdById], references: [id])

  @@index([organizationId, roomId, meterType, readingDate])
  @@index([leaseId, meterType, readingDate])
}

model Plan {
  id             String         @id @default(cuid())
  name           String
  apartmentLimit Int
  roomLimit      Int
  memberLimit    Int
  price          Decimal        @db.Decimal(12, 2)
  enabled        Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String
  planId         String
  startsAt       DateTime     @default(now())
  endsAt         DateTime?
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  plan           Plan         @relation(fields: [planId], references: [id])
}

model OrgQuotaPackage {
  id             String       @id @default(cuid())
  organizationId String
  apartmentQuota Int          @default(0)
  roomQuota      Int          @default(0)
  memberQuota    Int          @default(0)
  reason         String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}
