generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OtpPurpose {
  REGISTER
  LOGIN
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum RoomStatus {
  VACANT
  RESERVED
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRING_SOON
  TERMINATING
  TERMINATED
  EXPIRED
  ENDED
}

enum RentCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TerminationType {
  EXPIRED
  NEGOTIATED
  BREACH
}

enum BillStatus {
  DRAFT
  BILLING
  UNPAID
  PARTIAL_PAID
  PAID
  OVERDUE
  WRITTEN_OFF
  REFUNDED
  FAILED
  VOID
}

enum BillMode {
  PREPAID
  POSTPAID
  DEPOSIT
}

enum BillType {
  MONTHLY
  SETTLEMENT
  DEPOSIT
}

enum BillItemType {
  RENT
  SERVICE_FEE
  UTILITY
  ELECTRICITY
  WATER
  POWER
  GAS
  CARRY_OVER
  LATE_FEE
  DEPOSIT
  MANAGEMENT
  SANITATION
  ELEVATOR
  PROPERTY
  NETWORK
  PENALTY
  COMPENSATION
  CLEANING_FEE
  PREPAID_DEDUCTION
  DISCOUNT
  OTHER
}

enum MeterType {
  WATER
  POWER
  GAS
}

enum MeterStatus {
  ACTIVE
  REMOVED
}

enum MeterReadingSource {
  MANUAL
  IMPORT
}

enum MeterReadingStatus {
  NORMAL
  SUSPECTED
  CONFIRMED
  VOID
}

enum MeterReadingType {
  MANUAL
  SMART
  CHECKIN
  CHECKOUT
}

enum PlatformRole {
  USER
  SUPER_ADMIN
}

enum SettlementStatus {
  PENDING
  SETTLED
}

enum SettlementPaymentDirection {
  RECEIVE
  REFUND
}

enum SettlementItemType {
  RENT_ADJUSTMENT
  UTILITY
  DEPOSIT_REFUND
  DEPOSIT_DEDUCTION
  PENALTY
  COMPENSATION
  OTHER
}

enum CheckoutType {
  NORMAL
  EARLY
  FORCED
  ROOM_CHANGE
}

enum DepositStatus {
  UNPAID
  PAID
  PARTIAL_REFUNDED
  FULLY_REFUNDED
  DEDUCTED
}

enum DepositLedgerType {
  COLLECT
  DEDUCT
  REFUND
}

enum PaymentType {
  RECEIVE
  REFUND
  DEDUCT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum BillQueueStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  SKIPPED
  PAUSED
}

enum AccountTransactionType {
  PAYMENT
  CHARGE
  REFUND
  ADJUSTMENT
}

enum AccountReferenceType {
  BILL
  DEPOSIT
  SETTLEMENT
}

model User {
  id                 String              @id @default(cuid())
  phone              String              @unique
  username           String
  passwordHash       String
  passwordChangedAt  DateTime?
  platformRole       PlatformRole        @default(USER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        OrgMember[]
  payments           Payment[]
  meterReadings      MeterReading[]
  createdOrgInvites  OrgInvite[]         @relation("OrgInviteCreatedBy")
  usedOrgInvites     OrgInvite[]         @relation("OrgInviteUsedBy")
  settlementPayments SettlementPayment[]
  depositLedgers     DepositLedger[]
  auditLogs          AuditLog[]
}

model OtpCode {
  id        String     @id @default(cuid())
  phone     String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([phone, purpose])
}

model Organization {
  id              String            @id @default(cuid())
  name            String
  code            String            @unique
  description     String?
  status          OrgStatus         @default(ACTIVE)
  ownerId         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  members         OrgMember[]
  apartments      Apartment[]
  tenants         Tenant[]
  leases          Lease[]
  bills           Bill[]
  meterReadings   MeterReading[]
  meters          Meter[]
  quotas          OrgQuotaPackage[]
  subscriptions   Subscription[]
  invites         OrgInvite[]
  settlements     LeaseSettlement[]
  deposits        Deposit[]
  auditLogs       AuditLog[]
}

model Role {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String?
  system      Boolean     @default(false)
  permissions String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  members     OrgMember[]
}

model OrgMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  status         MemberStatus @default(ACTIVE)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role         @relation(fields: [roleId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

model OrgInvite {
  id             String       @id @default(cuid())
  organizationId String
  code           String       @unique
  maxUses        Int          @default(1)
  usedCount      Int          @default(0)
  expiresAt      DateTime
  createdById    String
  usedById       String?
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("OrgInviteCreatedBy", fields: [createdById], references: [id])
  usedBy         User?        @relation("OrgInviteUsedBy", fields: [usedById], references: [id])

  @@index([organizationId, createdAt])
  @@index([code, expiresAt])
}

model Apartment {
  id                   String             @id @default(cuid())
  organizationId       String
  name                 String
  location             String
  floors               Int
  landArea             Decimal?           @db.Decimal(12, 2)
  totalArea            Decimal?           @db.Decimal(12, 2)
  landlordName         String?
  landlordPhone        String?
  contractStart        DateTime?
  contractEnd          DateTime?
  rentAmount           Decimal?           @db.Decimal(12, 2)
  costElectricityPrice Decimal?           @db.Decimal(10, 4)
  costWaterPrice       Decimal?           @db.Decimal(10, 4)
  reminderDay          Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?
  organization         Organization       @relation(fields: [organizationId], references: [id])
  rooms                Room[]
  expenses             ApartmentExpense[]
  meterReadings        MeterReading[]
  meters               Meter[]
}

model ApartmentExpense {
  id          String    @id @default(cuid())
  apartmentId String
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  spentAt     DateTime
  note        String?
  deletedAt   DateTime?
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Room {
  id            String            @id @default(cuid())
  apartmentId   String
  roomNo        String
  layout        String
  area          Decimal?          @db.Decimal(10, 2)
  facilities    String[]
  status        RoomStatus        @default(VACANT)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  apartment     Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  leases        Lease[]
  meterReadings MeterReading[]
  meters        Meter[]
  settlements   LeaseSettlement[]

  @@unique([apartmentId, roomNo])
}

model Tenant {
  id               String          @id @default(cuid())
  organizationId   String
  name             String
  phone            String
  idCard           String?
  emergencyContact String?
  emergencyPhone   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  organization     Organization    @relation(fields: [organizationId], references: [id])
  leases           Lease[]
  account          TenantAccount?
  depositLedgers   DepositLedger[]

  @@unique([organizationId, phone])
  @@index([organizationId, name])
}

model Lease {
  id                String           @id @default(cuid())
  organizationId    String
  roomId            String
  tenantId          String?
  tenantName        String
  tenantPhone       String
  startDate         DateTime
  endDate           DateTime
  billDay           Int?
  utilityBillDay    Int?
  paymentDueDays    Int              @default(7)
  graceDays         Int              @default(0)
  cycle             RentCycle
  rentAmount        Decimal          @db.Decimal(12, 2)
  monthlyServiceFee Decimal          @default(0) @db.Decimal(12, 2)
  depositMonths     Int              @default(1)
  depositAmount     Decimal          @default(0) @db.Decimal(12, 2)
  waterUnitPrice    Decimal          @db.Decimal(10, 2)
  powerUnitPrice    Decimal          @db.Decimal(10, 2)
  lateFeeRate       Decimal          @default(0.0005) @db.Decimal(10, 6)
  autoRenew         Boolean          @default(false)
  status            LeaseStatus      @default(ACTIVE)
  terminationType   TerminationType?
  terminationReason String?
  terminatedAt      DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  organization      Organization     @relation(fields: [organizationId], references: [id])
  room              Room             @relation(fields: [roomId], references: [id])
  tenant            Tenant?          @relation(fields: [tenantId], references: [id])
  fees              LeaseFee[]
  bills             Bill[]
  meterReadings     MeterReading[]
  settlement        LeaseSettlement?
  deposit           Deposit?
  billQueue         BillQueue?
  depositLedgers    DepositLedger[]
}

model LeaseSettlement {
  id                     String              @id @default(cuid())
  organizationId         String
  leaseId                String              @unique
  roomId                 String
  billId                 String?             @unique
  checkoutType           CheckoutType?
  type                   TerminationType
  reason                 String?
  terminatedAt           DateTime
  depositAmount          Decimal             @db.Decimal(12, 2)
  depositDeductionAmount Decimal             @default(0) @db.Decimal(12, 2)
  depositDeductionReason String?
  depositRefundAmount    Decimal             @default(0) @db.Decimal(12, 2)
  rentAdjustmentAmount   Decimal             @default(0) @db.Decimal(12, 2)
  previousWater          Decimal             @default(0) @db.Decimal(12, 2)
  currentWater           Decimal             @default(0) @db.Decimal(12, 2)
  previousPower          Decimal             @default(0) @db.Decimal(12, 2)
  currentPower           Decimal             @default(0) @db.Decimal(12, 2)
  waterUnitPrice         Decimal             @default(0) @db.Decimal(10, 2)
  powerUnitPrice         Decimal             @default(0) @db.Decimal(10, 2)
  utilityAmount          Decimal             @default(0) @db.Decimal(12, 2)
  otherFeeAmount         Decimal             @default(0) @db.Decimal(12, 2)
  otherFeeReason         String?
  penaltyAmount          Decimal             @default(0) @db.Decimal(12, 2)
  penaltyReason          String?
  compensationAmount     Decimal             @default(0) @db.Decimal(12, 2)
  compensationReason     String?
  receivableAmount       Decimal             @default(0) @db.Decimal(12, 2)
  refundableAmount       Decimal             @default(0) @db.Decimal(12, 2)
  netAmount              Decimal             @default(0) @db.Decimal(12, 2)
  status                 SettlementStatus    @default(PENDING)
  tenantSignature        String?
  operatorSignature      String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  deletedAt              DateTime?
  organization           Organization        @relation(fields: [organizationId], references: [id])
  lease                  Lease               @relation(fields: [leaseId], references: [id])
  room                   Room                @relation(fields: [roomId], references: [id])
  bill                   Bill?               @relation(fields: [billId], references: [id])
  payments               SettlementPayment[]
  items                  SettlementItem[]

  @@index([organizationId, status])
  @@index([roomId, terminatedAt])
}

model SettlementItem {
  id           String              @id @default(cuid())
  settlementId String
  type         SettlementItemType
  name         String
  amount       Decimal             @db.Decimal(12, 2)
  note         String?
  createdAt    DateTime            @default(now())
  settlement   LeaseSettlement     @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
}

model SettlementPayment {
  id           String                     @id @default(cuid())
  settlementId String
  userId       String
  direction    SettlementPaymentDirection
  amount       Decimal                    @db.Decimal(12, 2)
  paidAt       DateTime                   @default(now())
  method       String
  note         String?
  deletedAt    DateTime?
  settlement   LeaseSettlement            @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  user         User                       @relation(fields: [userId], references: [id])

  @@index([settlementId, paidAt])
}

model Deposit {
  id             String          @id @default(cuid())
  organizationId String
  leaseId        String          @unique
  billId         String?         @unique
  amount         Decimal         @db.Decimal(12, 2)
  paidAmount     Decimal         @default(0) @db.Decimal(12, 2)
  refundedAmount Decimal         @default(0) @db.Decimal(12, 2)
  deductedAmount Decimal         @default(0) @db.Decimal(12, 2)
  status         DepositStatus   @default(UNPAID)
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id])
  lease          Lease           @relation(fields: [leaseId], references: [id])
  bill           Bill?           @relation("BillDeposit", fields: [billId], references: [id])
  depositLedgers DepositLedger[]

  @@index([organizationId, status])
}

model DepositLedger {
  id            String            @id @default(cuid())
  depositId     String
  leaseId       String
  tenantId      String
  amount        Decimal           @db.Decimal(12, 2)
  type          DepositLedgerType
  relatedBillId String?
  balanceAfter  Decimal           @db.Decimal(12, 2)
  remark        String?
  operatorId    String
  createdAt     DateTime          @default(now())
  deposit       Deposit           @relation(fields: [depositId], references: [id], onDelete: Cascade)
  lease         Lease             @relation(fields: [leaseId], references: [id])
  operator      User              @relation(fields: [operatorId], references: [id])
  bill          Bill?             @relation(fields: [relatedBillId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id])

  @@index([depositId, createdAt])
  @@index([leaseId, createdAt])
  @@index([tenantId, createdAt])
}

model LeaseFee {
  id        String       @id @default(cuid())
  leaseId   String
  type      BillItemType @default(OTHER)
  name      String
  amount    Decimal      @db.Decimal(10, 2)
  deletedAt DateTime?
  lease     Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

model Bill {
  id                 String              @id @default(cuid())
  organizationId     String
  leaseId            String
  mode               BillMode            @default(PREPAID)
  type               BillType            @default(MONTHLY)
  billingDate        DateTime
  periodStart        DateTime
  periodEnd          DateTime
  dueDate            DateTime
  status             BillStatus          @default(UNPAID)
  totalAmount        Decimal             @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal             @default(0) @db.Decimal(12, 2)
  netAmount          Decimal             @default(0) @db.Decimal(12, 2)
  paidAmount         Decimal             @default(0) @db.Decimal(12, 2)
  note               String?
  failureReason      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  organization       Organization        @relation(fields: [organizationId], references: [id])
  lease              Lease               @relation(fields: [leaseId], references: [id])
  items              BillItem[]
  deposit            Deposit?            @relation("BillDeposit")
  depositLedgers     DepositLedger[]
  settlement         LeaseSettlement?
  payments           Payment[]
  paymentAllocations PaymentAllocation[]

  @@unique([leaseId, billingDate, mode])
  @@index([organizationId, status])
  @@index([leaseId, billingDate])
}

model BillItem {
  id             String            @id @default(cuid())
  billId         String
  type           BillItemType
  name           String
  description    String?
  quantity       Decimal?          @db.Decimal(12, 4)
  unitPrice      Decimal?          @db.Decimal(10, 4)
  amount         Decimal           @default(0) @db.Decimal(12, 2)
  status         BillStatus        @default(UNPAID)
  previousWater  Decimal?          @db.Decimal(12, 2)
  currentWater   Decimal?          @db.Decimal(12, 2)
  previousPower  Decimal?          @db.Decimal(12, 2)
  currentPower   Decimal?          @db.Decimal(12, 2)
  waterUnitPrice Decimal?          @db.Decimal(10, 2)
  powerUnitPrice Decimal?          @db.Decimal(10, 2)
  meterReadingId String?
  note           String?
  deletedAt      DateTime?
  bill           Bill              @relation(fields: [billId], references: [id], onDelete: Cascade)
  meterReading   MeterReading?     @relation(fields: [meterReadingId], references: [id])
  readings       BillItemReading[]
}

model BillItemReading {
  id             String    @id @default(cuid())
  billItemId     String
  meterType      MeterType
  previousValue  Decimal   @db.Decimal(12, 2)
  currentValue   Decimal   @db.Decimal(12, 2)
  unitPrice      Decimal   @db.Decimal(10, 2)
  usage          Decimal   @db.Decimal(12, 2)
  amount         Decimal   @db.Decimal(12, 2)
  meterId        String?
  meterReadingId String?
  createdAt      DateTime  @default(now())
  billItem       BillItem  @relation(fields: [billItemId], references: [id], onDelete: Cascade)
  meter          Meter?    @relation(fields: [meterId], references: [id])
  meterReading   MeterReading? @relation(fields: [meterReadingId], references: [id])

  @@index([billItemId])
}

model Payment {
  id             String              @id @default(cuid())
  billId         String?
  tenantId       String?
  userId         String
  type           PaymentType         @default(RECEIVE)
  amount         Decimal             @db.Decimal(12, 2)
  paidAt         DateTime            @default(now())
  method         String
  transactionNo  String?
  note           String?
  status         PaymentStatus       @default(COMPLETED)
  deletedAt      DateTime?
  bill           Bill?               @relation(fields: [billId], references: [id])
  user           User                @relation(fields: [userId], references: [id])
  allocations    PaymentAllocation[]

  @@index([billId, paidAt])
  @@index([tenantId, paidAt])
}

model PaymentAllocation {
  id              String   @id @default(cuid())
  paymentId       String
  billId          String
  allocatedAmount Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([billId])
}

model Meter {
  id             String       @id @default(cuid())
  organizationId String
  apartmentId    String
  roomId         String?
  name           String
  meterType      MeterType
  meterNo        String?
  installDate    DateTime     @default(now())
  removeDate     DateTime?
  status         MeterStatus  @default(ACTIVE)
  parentId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  apartment      Apartment    @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  room           Room?        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  parent         Meter?       @relation("MeterHierarchy", fields: [parentId], references: [id])
  subMeters      Meter[]      @relation("MeterHierarchy")
  readings       MeterReading[]
  billItemReadings BillItemReading[]

  @@index([organizationId, apartmentId])
  @@index([roomId, status])
}

model MeterReading {
  id               String             @id @default(cuid())
  organizationId   String
  apartmentId      String
  roomId           String
  leaseId          String?
  meterId          String?
  meterType        MeterType
  readingDate      DateTime
  value            Decimal            @db.Decimal(12, 2)
  usage            Decimal?           @db.Decimal(12, 2)
  source           MeterReadingSource @default(MANUAL)
  readType         MeterReadingType   @default(MANUAL)
  status           MeterReadingStatus @default(NORMAL)
  photoUrl         String?
  note             String?
  createdById      String?
  createdAt        DateTime           @default(now())
  deletedAt        DateTime?
  organization     Organization       @relation(fields: [organizationId], references: [id])
  apartment        Apartment          @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  room             Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  lease            Lease?             @relation(fields: [leaseId], references: [id])
  meter            Meter?             @relation(fields: [meterId], references: [id])
  createdBy        User?              @relation(fields: [createdById], references: [id])
  billItems        BillItem[]
  billItemReadings BillItemReading[]

  @@index([organizationId, roomId, meterType, readingDate])
  @@index([leaseId, meterType, readingDate])
  @@index([meterId, readingDate])
}

model BillQueue {
  id           String          @id @default(cuid())
  leaseId      String          @unique
  nextBillDate DateTime
  lastBillDate DateTime?
  lastBillId   String?
  status       BillQueueStatus @default(PENDING)
  errorMsg     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lease        Lease           @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([nextBillDate, status])
}

model TenantAccount {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  prepaidBalance Decimal  @default(0) @db.Decimal(12, 2)
  depositBalance Decimal  @default(0) @db.Decimal(12, 2)
  totalUnpaid    Decimal  @default(0) @db.Decimal(12, 2)
  netBalance     Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions   AccountTransaction[]
}

model AccountTransaction {
  id              String                  @id @default(cuid())
  tenantAccountId String
  type            AccountTransactionType
  amount          Decimal                 @db.Decimal(12, 2)
  balanceAfter    Decimal                 @db.Decimal(12, 2)
  referenceType   AccountReferenceType?
  referenceId     String?
  note            String?
  createdById     String?
  createdAt       DateTime                @default(now())
  tenantAccount   TenantAccount           @relation(fields: [tenantAccountId], references: [id], onDelete: Cascade)

  @@index([tenantAccountId, createdAt])
}

model Plan {
  id             String         @id @default(cuid())
  name           String
  apartmentLimit Int
  roomLimit      Int
  memberLimit    Int
  price          Decimal        @db.Decimal(12, 2)
  enabled        Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String
  planId         String
  startsAt       DateTime     @default(now())
  endsAt         DateTime?
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  plan           Plan         @relation(fields: [planId], references: [id])
}

model OrgQuotaPackage {
  id             String       @id @default(cuid())
  organizationId String
  apartmentQuota Int          @default(0)
  roomQuota      Int          @default(0)
  memberQuota    Int          @default(0)
  reason         String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  tableName      String
  recordId       String
  action         String
  fieldName      String?
  oldValue       String?
  newValue       String?
  userId         String
  ipAddress      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId, tableName, recordId])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}
