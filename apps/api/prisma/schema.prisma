generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举定义 ====================

enum OtpPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum MemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ApartmentStatus {
  PLANNING
  RENOVATING
  PREPARING
  ACTIVE
  SUSPENDED
  CLOSED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL_RENOVATED
  URBAN_VILLAGE
  OTHER
}

enum PropertyRight {
  OWNED
  LONG_TERM_LEASE
  TRUSTEESHIP
}

enum RoomStatus {
  TO_RENOVATE
  TO_CONFIGURE
  VACANT
  RESERVED
  OCCUPIED
  MAINTENANCE
  CHECKOUT_CLEANING
}

enum LeaseStatus {
  DRAFT
  PENDING
  ACTIVE
  EXPIRING_SOON
  TERMINATING
  TERMINATED
  EXPIRED
  RENEWED
}

enum RentCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TerminationType {
  EXPIRED
  NEGOTIATED
  BREACH
  FORCED
}

enum CheckoutType {
  NORMAL
  EARLY
  FORCED
  ROOM_CHANGE
}

enum BillStatus {
  DRAFT
  BILLING
  UNPAID
  PARTIAL_PAID
  PAID
  OVERDUE
  WRITTEN_OFF
  REFUNDED
  FAILED
  VOID
}

enum BillMode {
  PREPAID
  POSTPAID
  DEPOSIT
}

enum BillType {
  MONTHLY
  SETTLEMENT
  DEPOSIT
}

enum BillItemType {
  RENT
  SERVICE_FEE
  UTILITY
  ELECTRICITY
  WATER
  POWER
  GAS
  CARRY_OVER
  LATE_FEE
  DEPOSIT
  MANAGEMENT
  SANITATION
  ELEVATOR
  PROPERTY
  NETWORK
  PENALTY
  COMPENSATION
  CLEANING_FEE
  PREPAID_DEDUCTION
  DISCOUNT
  REFUND
  OTHER
}

enum MeterType {
  WATER
  POWER
  GAS
}

enum MeterStatus {
  ACTIVE
  REMOVED
}

enum MeterReadingSource {
  MANUAL
  IMPORT
}

enum MeterReadingStatus {
  NORMAL
  SUSPECTED
  CONFIRMED
  VOID
}

enum MeterReadingType {
  MANUAL
  SMART
  CHECKIN
  CHECKOUT
}

enum PlatformRole {
  USER
  SUPER_ADMIN
}

enum SettlementStatus {
  PENDING
  SETTLED
}

enum SettlementPaymentDirection {
  RECEIVE
  REFUND
}

enum SettlementItemType {
  RENT_ADJUSTMENT
  UTILITY
  DEPOSIT_REFUND
  DEPOSIT_DEDUCTION
  PENALTY
  COMPENSATION
  OTHER
}

enum DepositStatus {
  UNPAID
  PAID
  PARTIAL_REFUNDED
  FULLY_REFUNDED
  DEDUCTED
}

enum DepositLedgerType {
  COLLECT
  DEDUCT
  REFUND
  TRANSFER
}

enum PaymentType {
  RECEIVE
  REFUND
  DEDUCT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum BillQueueStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  SKIPPED
  PAUSED
}

enum AccountTransactionType {
  PAYMENT
  CHARGE
  REFUND
  ADJUSTMENT
}

enum AccountReferenceType {
  BILL
  DEPOSIT
  SETTLEMENT
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum RefundType {
  DEPOSIT
  PREPAID
  OVERPAY
}

enum MaintenanceOrderStatus {
  PENDING
  DISPATCHED
  IN_PROGRESS
  AWAITING_ACCEPTANCE
  COMPLETED
  CANCELLED
}

enum MaintenanceOrderType {
  WATER_ELECTRIC
  DOOR_WINDOW
  WALL
  FURNITURE_APPLIANCE
  NETWORK
  PIPE
  CLEANING
  OTHER
}

enum MaintenancePriority {
  URGENT
  NORMAL
  LOW
}

enum RoomCheckType {
  CHECKIN
  CHECKOUT
}

enum IncomeExpenseType {
  INCOME
  EXPENSE
}

enum CashierAccountType {
  CASH
  BANK
  WECHAT
  ALIPAY
  POS
  OTHER
}

enum InvoiceStatus {
  PENDING
  ISSUED
  SENT
  RECEIVED
}

enum TenantSource {
  PLATFORM_58
  DOUBAN
  BEIKE
  REFERRAL
  AGENT
  WALK_IN
  OTHER
}

enum Orientation {
  NORTH
  SOUTH
  EAST
  WEST
  NORTH_EAST
  NORTH_WEST
  SOUTH_EAST
  SOUTH_WEST
}

enum DecorationStatus {
  BARE
  SIMPLE
  DELUXE
  LUXURY
}

// ==================== 用户与权限 ====================

model User {
  id                 String              @id @default(cuid())
  phone              String              @unique
  username           String
  passwordHash       String
  passwordChangedAt  DateTime?
  platformRole       PlatformRole        @default(USER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        OrgMember[]
  payments           Payment[]
  meterReadings      MeterReading[]
  createdOrgInvites  OrgInvite[]         @relation("OrgInviteCreatedBy")
  usedOrgInvites     OrgInvite[]         @relation("OrgInviteUsedBy")
  settlementPayments SettlementPayment[]
  depositLedgers     DepositLedger[]
  auditLogs          AuditLog[]
  maintenanceOrders  MaintenanceOrder[]
  cashierJournals    CashierJournal[]
  invoices           Invoice[]
  notifications      Notification[]
  refunds            Refund[]
  ownedOrganizations Organization[]
}

model OtpCode {
  id        String     @id @default(cuid())
  phone     String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([phone, purpose])
}

model Organization {
  id                String                @id @default(cuid())
  name              String
  code              String                @unique
  description       String?
  status            OrgStatus             @default(ACTIVE)
  ownerId           String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  owner             User                  @relation(fields: [ownerId], references: [id])
  members           OrgMember[]
  apartments        Apartment[]
  tenants           Tenant[]
  leases            Lease[]
  bills             Bill[]
  meterReadings     MeterReading[]
  meters            Meter[]
  quotas            OrgQuotaPackage[]
  subscriptions     Subscription[]
  invites           OrgInvite[]
  settlements       LeaseSettlement[]
  deposits          Deposit[]
  auditLogs         AuditLog[]
  maintenanceOrders MaintenanceOrder[]
  roomChecklists    RoomChecklist[]
  cashierJournals   CashierJournal[]
  incomeCategories  IncomeExpenseCategory[]
  invoices          Invoice[]
  notifications     Notification[]
  accounts          Account[]
  accountTransfers  AccountTransfer[]
  refunds           Refund[]
}

model Role {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String?
  system      Boolean     @default(false)
  permissions String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  members     OrgMember[]
}

model OrgMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  status         MemberStatus @default(ACTIVE)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role         @relation(fields: [roleId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

model OrgInvite {
  id             String       @id @default(cuid())
  organizationId String
  code           String       @unique
  maxUses        Int          @default(1)
  usedCount      Int          @default(0)
  expiresAt      DateTime
  createdById    String
  usedById       String?
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("OrgInviteCreatedBy", fields: [createdById], references: [id])
  usedBy         User?        @relation("OrgInviteUsedBy", fields: [usedById], references: [id])

  @@index([organizationId, createdAt])
  @@index([code, expiresAt])
}

// ==================== 物业资产 ====================

model Apartment {
  id                   String             @id @default(cuid())
  organizationId       String
  name                 String
  location             String
  status               ApartmentStatus    @default(ACTIVE)
  statusReason         String?
  statusChangedAt      DateTime           @default(now())
  propertyType         PropertyType       @default(RESIDENTIAL)
  floors               Int
  landArea             Decimal?           @db.Decimal(12, 2)
  totalArea            Decimal?           @db.Decimal(12, 2)
  publicAreaRatio      Decimal?           @db.Decimal(5, 4) // 公摊比例
  buildYear            Int?
  elevatorCount        Int                @default(0)
  propertyRight        PropertyRight      @default(LONG_TERM_LEASE)
  costElectricityPrice Decimal?           @db.Decimal(10, 4)
  costWaterPrice       Decimal?           @db.Decimal(10, 4)
  costGasPrice         Decimal?           @db.Decimal(10, 4)
  reminderDay          Int?               @default(3)
  fireRating           String?            // 消防等级
  fireExtinguisherCount Int?              // 灭火器数量
  escapeRouteCount     Int?               // 逃生通道数量
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?
  organization         Organization       @relation(fields: [organizationId], references: [id])
  rooms                Room[]
  expenses             ApartmentExpense[]
  meterReadings        MeterReading[]
  meters               Meter[]
  maintenanceOrders    MaintenanceOrder[]
  landlordContracts    LandlordContract[]
  landlordPayments     LandlordPayment[]

  @@index([organizationId, status])
}

model LandlordContract {
  id            String    @id @default(cuid())
  apartmentId   String
  contractNo    String?
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal   @db.Decimal(12, 2)
  depositAmount Decimal   @db.Decimal(12, 2)
  paymentMethod String    // 月付/季付/半年付/年付
  escalationType String?  // FIXED_AMOUNT / PERCENTAGE
  escalationValue Decimal? @db.Decimal(10, 4)
  escalationCycle Int?
  freeRentDays  Int       @default(0)
  freeRentStart DateTime?
  freeRentEnd   DateTime?
  signDate      DateTime?
  attachmentUrl String?
  note          String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  apartment     Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  payments      LandlordPayment[]

  @@index([apartmentId, isActive])
}

model LandlordPayment {
  id                 String    @id @default(cuid())
  organizationId     String
  landlordContractId String
  apartmentId        String
  periodStart        DateTime
  periodEnd          DateTime
  dueDate            DateTime
  plannedAmount      Decimal   @db.Decimal(12, 2)
  paidAmount         Decimal?  @db.Decimal(12, 2)
  paidAt             DateTime?
  voucherNo          String?
  paymentMethod      String?   // CASH / BANK_TRANSFER / WECHAT / ALIPAY
  status             String    @default("PENDING") // PENDING / PAID / OVERDUE
  expenseId          String? @unique
  note               String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  landlordContract   LandlordContract  @relation(fields: [landlordContractId], references: [id], onDelete: Cascade)
  apartment          Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  expense            ApartmentExpense? @relation(fields: [expenseId], references: [id])

  @@index([organizationId, status])
  @@index([landlordContractId, dueDate])
  @@index([apartmentId, status])
}

model ApartmentExpense {
  id          String    @id @default(cuid())
  apartmentId String
  categoryId  String?
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  spentAt     DateTime
  note        String?
  createdById String?
  deletedAt   DateTime?
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  category    IncomeExpenseCategory? @relation(fields: [categoryId], references: [id])
  landlordPayment LandlordPayment?

  @@index([apartmentId, spentAt])
}

model Room {
  id                 String            @id @default(cuid())
  apartmentId        String
  roomNo             String
  floor              Int               @default(1)
  layout             String
  area               Decimal?          @db.Decimal(10, 2)
  orientation        Orientation?
  decorationStatus   DecorationStatus  @default(SIMPLE)
  decorationDate     DateTime?
  facilities         String[]
  status             RoomStatus        @default(VACANT)
  statusChangedAt    DateTime          @default(now())
  statusReason       String?
  currentRentPrice   Decimal?          @db.Decimal(12, 2)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  apartment          Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  leases             Lease[]
  meterReadings      MeterReading[]
  meters             Meter[]
  settlements        LeaseSettlement[]
  maintenanceOrders  MaintenanceOrder[]
  roomChecklists     RoomChecklist[]

  @@unique([apartmentId, roomNo])
  @@index([apartmentId, status])
}

// ==================== 租客 ====================

model Tenant {
  id               String          @id @default(cuid())
  organizationId   String
  name             String
  phone            String
  idCard           String?
  idCardFrontUrl   String?
  idCardBackUrl    String?
  workUnit         String?
  jobTitle         String?
  emergencyContact String?
  emergencyPhone   String?
  sourceChannel    TenantSource    @default(OTHER)
  creditScore      Int             @default(100)
  remark           String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  organization     Organization    @relation(fields: [organizationId], references: [id])
  leases           Lease[]
  account          TenantAccount?
  depositLedgers   DepositLedger[]
  coResidents      CoResident[]
  invoices         Invoice[]
  refunds          Refund[]

  @@unique([organizationId, phone])
  @@index([organizationId, name])
}

model CoResident {
  id          String    @id @default(cuid())
  tenantId    String
  leaseId     String
  name        String
  idCard      String?
  phone       String?
  relation    String    // 配偶/父母/子女/朋友/同事/其他
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease       Lease     @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([leaseId])
}

// ==================== 租约 ====================

model Lease {
  id                    String             @id @default(cuid())
  organizationId        String
  roomId                String
  tenantId              String?
  tenantName            String
  tenantPhone           String
  contractDate          DateTime           @default(now())
  startDate             DateTime
  endDate               DateTime
  billDay               Int?               @default(1)
  utilityBillDay        Int?
  paymentDueDays        Int                @default(7)
  graceDays             Int                @default(0)
  cycle                 RentCycle
  rentAmount            Decimal            @db.Decimal(12, 2)
  monthlyServiceFee     Decimal            @default(0) @db.Decimal(12, 2)
  depositMonths         Int                @default(1)
  depositAmount         Decimal            @default(0) @db.Decimal(12, 2)
  waterUnitPrice        Decimal            @db.Decimal(10, 2)
  powerUnitPrice        Decimal            @db.Decimal(10, 2)
  gasUnitPrice          Decimal?           @db.Decimal(10, 2)
  waterPricingTiers     Json?
  powerPricingTiers     Json?
  lateFeeRate           Decimal            @default(0.0005) @db.Decimal(10, 6)
  freeRentDays          Int                @default(0)
  freeRentStart         DateTime?
  freeRentEnd           DateTime?
  rentEscalationEnabled Boolean            @default(false)
  nextEscalationDate    DateTime?
  autoRenew             Boolean            @default(false)
  signedBy              String?
  remark                String?
  status                LeaseStatus        @default(ACTIVE)
  terminationType       TerminationType?
  terminationReason     String?
  terminatedAt          DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?
  organization          Organization       @relation(fields: [organizationId], references: [id])
  room                  Room               @relation(fields: [roomId], references: [id])
  tenant                Tenant?            @relation(fields: [tenantId], references: [id])
  fees                  LeaseFee[]
  bills                 Bill[]
  meterReadings         MeterReading[]
  settlement            LeaseSettlement?
  deposit               Deposit?
  billQueue             BillQueue?
  depositLedgers        DepositLedger[]
  changeLogs            LeaseChangeLog[]
  coResidents           CoResident[]
  roomChecklists        RoomChecklist[]
  parentLease           Lease?             @relation("LeaseRenewal", fields: [parentLeaseId], references: [id])
  parentLeaseId         String?
  childLeases           Lease[]            @relation("LeaseRenewal")

  @@index([roomId, status])
  @@index([tenantId, status])
  @@index([organizationId, status])
}

model LeaseFee {
  id        String       @id @default(cuid())
  leaseId   String
  type      BillItemType @default(OTHER)
  name      String
  amount    Decimal      @db.Decimal(10, 2)
  deletedAt DateTime?
  lease     Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

model LeaseChangeLog {
  id            String   @id @default(cuid())
  leaseId       String
  fieldName     String
  oldValue      String?
  newValue      String?
  reason        String?
  changedById   String?
  changedAt     DateTime @default(now())
  lease         Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId, changedAt])
}

// ==================== 退租结算 ====================

model LeaseSettlement {
  id                     String              @id @default(cuid())
  organizationId         String
  leaseId                String              @unique
  roomId                 String
  billId                 String?             @unique
  checkoutType           CheckoutType?
  type                   TerminationType
  reason                 String?
  terminatedAt           DateTime
  depositAmount          Decimal             @db.Decimal(12, 2)
  depositDeductionAmount Decimal             @default(0) @db.Decimal(12, 2)
  depositDeductionReason String?
  depositRefundAmount    Decimal             @default(0) @db.Decimal(12, 2)
  rentAdjustmentAmount   Decimal             @default(0) @db.Decimal(12, 2)
  previousWater          Decimal             @default(0) @db.Decimal(12, 2)
  currentWater           Decimal             @default(0) @db.Decimal(12, 2)
  previousPower          Decimal             @default(0) @db.Decimal(12, 2)
  currentPower           Decimal             @default(0) @db.Decimal(12, 2)
  previousGas            Decimal             @default(0) @db.Decimal(12, 2)
  currentGas             Decimal             @default(0) @db.Decimal(12, 2)
  waterUnitPrice         Decimal             @default(0) @db.Decimal(10, 2)
  powerUnitPrice         Decimal             @default(0) @db.Decimal(10, 2)
  gasUnitPrice           Decimal             @default(0) @db.Decimal(10, 2)
  utilityAmount          Decimal             @default(0) @db.Decimal(12, 2)
  otherFeeAmount         Decimal             @default(0) @db.Decimal(12, 2)
  otherFeeReason         String?
  penaltyAmount          Decimal             @default(0) @db.Decimal(12, 2)
  penaltyReason          String?
  compensationAmount     Decimal             @default(0) @db.Decimal(12, 2)
  compensationReason     String?
  receivableAmount       Decimal             @default(0) @db.Decimal(12, 2)
  refundableAmount       Decimal             @default(0) @db.Decimal(12, 2)
  netAmount              Decimal             @default(0) @db.Decimal(12, 2)
  status                 SettlementStatus    @default(PENDING)
  tenantSignature        String?
  operatorSignature      String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  deletedAt              DateTime?
  organization           Organization        @relation(fields: [organizationId], references: [id])
  lease                  Lease               @relation(fields: [leaseId], references: [id])
  room                   Room                @relation(fields: [roomId], references: [id])
  bill                   Bill?               @relation(fields: [billId], references: [id])
  payments               SettlementPayment[]
  items                  SettlementItem[]

  @@index([organizationId, status])
  @@index([roomId, terminatedAt])
}

model SettlementItem {
  id           String              @id @default(cuid())
  settlementId String
  type         SettlementItemType
  name         String
  amount       Decimal             @db.Decimal(12, 2)
  note         String?
  createdAt    DateTime            @default(now())
  settlement   LeaseSettlement     @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
}

model SettlementPayment {
  id           String                     @id @default(cuid())
  settlementId String
  userId       String
  direction    SettlementPaymentDirection
  amount       Decimal                    @db.Decimal(12, 2)
  paidAt       DateTime                   @default(now())
  method       String
  note         String?
  deletedAt    DateTime?
  settlement   LeaseSettlement            @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  user         User                       @relation(fields: [userId], references: [id])

  @@index([settlementId, paidAt])
}

// ==================== 押金 ====================

model Deposit {
  id             String          @id @default(cuid())
  organizationId String
  leaseId        String          @unique
  billId         String?         @unique
  amount         Decimal         @db.Decimal(12, 2)
  paidAmount     Decimal         @default(0) @db.Decimal(12, 2)
  refundedAmount Decimal         @default(0) @db.Decimal(12, 2)
  deductedAmount Decimal         @default(0) @db.Decimal(12, 2)
  transferredAmount Decimal      @default(0) @db.Decimal(12, 2)
  status         DepositStatus   @default(UNPAID)
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  organization   Organization    @relation(fields: [organizationId], references: [id])
  lease          Lease           @relation(fields: [leaseId], references: [id])
  bill           Bill?           @relation("BillDeposit", fields: [billId], references: [id])
  depositLedgers DepositLedger[]

  @@index([organizationId, status])
}

model DepositLedger {
  id            String            @id @default(cuid())
  depositId     String
  leaseId       String
  tenantId      String
  amount        Decimal           @db.Decimal(12, 2)
  type          DepositLedgerType
  relatedBillId String?
  balanceAfter  Decimal           @db.Decimal(12, 2)
  remark        String?
  operatorId    String
  createdAt     DateTime          @default(now())
  deposit       Deposit           @relation(fields: [depositId], references: [id], onDelete: Cascade)
  lease         Lease             @relation(fields: [leaseId], references: [id])
  operator      User              @relation(fields: [operatorId], references: [id])
  bill          Bill?             @relation(fields: [relatedBillId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id])

  @@index([depositId, createdAt])
  @@index([leaseId, createdAt])
  @@index([tenantId, createdAt])
}

// ==================== 账单 ====================

model Bill {
  id                 String              @id @default(cuid())
  organizationId     String
  leaseId            String
  mode               BillMode            @default(PREPAID)
  type               BillType            @default(MONTHLY)
  billingDate        DateTime
  periodStart        DateTime
  periodEnd          DateTime
  dueDate            DateTime
  status             BillStatus          @default(UNPAID)
  totalAmount        Decimal             @default(0) @db.Decimal(12, 2)
  discountAmount     Decimal             @default(0) @db.Decimal(12, 2)
  netAmount          Decimal             @default(0) @db.Decimal(12, 2)
  paidAmount         Decimal             @default(0) @db.Decimal(12, 2)
  note               String?
  failureReason      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  organization       Organization        @relation(fields: [organizationId], references: [id])
  lease              Lease               @relation(fields: [leaseId], references: [id])
  items              BillItem[]
  deposit            Deposit?            @relation("BillDeposit")
  depositLedgers     DepositLedger[]
  settlement         LeaseSettlement?
  payments           Payment[]
  paymentAllocations PaymentAllocation[]
  invoices           Invoice[]
  overduePenalties   OverduePenalty[]

  @@unique([leaseId, billingDate, mode])
  @@index([organizationId, status])
  @@index([leaseId, billingDate])
}

model BillItem {
  id             String            @id @default(cuid())
  billId         String
  type           BillItemType
  name           String
  description    String?
  quantity       Decimal?          @db.Decimal(12, 4)
  unitPrice      Decimal?          @db.Decimal(10, 4)
  amount         Decimal           @default(0) @db.Decimal(12, 2)
  status         BillStatus        @default(UNPAID)
  previousWater  Decimal?          @db.Decimal(12, 2)
  currentWater   Decimal?          @db.Decimal(12, 2)
  previousPower  Decimal?          @db.Decimal(12, 2)
  currentPower   Decimal?          @db.Decimal(12, 2)
  previousGas    Decimal?          @db.Decimal(12, 2)
  currentGas     Decimal?          @db.Decimal(12, 2)
  waterUnitPrice Decimal?          @db.Decimal(10, 2)
  powerUnitPrice Decimal?          @db.Decimal(10, 2)
  gasUnitPrice   Decimal?          @db.Decimal(10, 2)
  meterReadingId String?
  note           String?
  deletedAt      DateTime?
  bill           Bill              @relation(fields: [billId], references: [id], onDelete: Cascade)
  meterReading   MeterReading?     @relation(fields: [meterReadingId], references: [id])
  readings       BillItemReading[]

  @@index([billId, type])
}

model BillItemReading {
  id             String        @id @default(cuid())
  billItemId     String
  meterType      MeterType
  previousValue  Decimal       @db.Decimal(12, 2)
  currentValue   Decimal       @db.Decimal(12, 2)
  unitPrice      Decimal       @db.Decimal(10, 2)
  usage          Decimal       @db.Decimal(12, 2)
  amount         Decimal       @db.Decimal(12, 2)
  meterId        String?
  meterReadingId String?
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  billItem       BillItem      @relation(fields: [billItemId], references: [id], onDelete: Cascade)
  meter          Meter?        @relation(fields: [meterId], references: [id])
  meterReading   MeterReading? @relation(fields: [meterReadingId], references: [id])

  @@index([billItemId])
}

// ==================== 收款与支付 ====================

model Payment {
  id             String              @id @default(cuid())
  billId         String?
  tenantId       String?
  userId         String
  type           PaymentType         @default(RECEIVE)
  amount         Decimal             @db.Decimal(12, 2)
  paidAt         DateTime            @default(now())
  method         String
  transactionNo  String?
  note           String?
  status         PaymentStatus       @default(COMPLETED)
  deletedAt      DateTime?
  bill           Bill?               @relation(fields: [billId], references: [id])
  user           User                @relation(fields: [userId], references: [id])
  allocations    PaymentAllocation[]

  @@index([billId, paidAt])
  @@index([tenantId, paidAt])
}

model PaymentAllocation {
  id              String   @id @default(cuid())
  paymentId       String
  billId          String
  allocatedAmount Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  bill            Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([billId])
}

// ==================== 滞纳金 ====================

model OverduePenalty {
  id           String   @id @default(cuid())
  billId       String
  leaseId      String
  amount       Decimal  @db.Decimal(12, 2)
  baseAmount   Decimal  @db.Decimal(12, 2)
  daysOverdue  Int
  rate         Decimal  @db.Decimal(10, 6)
  isWaived     Boolean  @default(false)
  waiveReason  String?
  waivedById   String?
  waivedAt     DateTime?
  calculatedAt DateTime @default(now())
  bill         Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([leaseId])
}

// ==================== 发票 ====================

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  tenantId       String?
  billId         String?
  title          String
  taxNo          String?
  amount         Decimal       @db.Decimal(12, 2)
  content        String?
  email          String?
  address        String?
  status         InvoiceStatus @default(PENDING)
  issuedAt       DateTime?
  sentAt         DateTime?
  receivedAt     DateTime?
  note           String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  organization   Organization  @relation(fields: [organizationId], references: [id])
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])
  bill           Bill?         @relation(fields: [billId], references: [id])
  createdBy      User          @relation(fields: [createdById], references: [id])

  @@index([organizationId, status])
  @@index([tenantId])
}

// ==================== 表具 ====================

model Meter {
  id               String            @id @default(cuid())
  organizationId   String
  apartmentId      String
  roomId           String?
  name             String
  meterType        MeterType
  meterNo          String?
  installDate      DateTime          @default(now())
  removeDate       DateTime?
  initialValue     Decimal           @default(0) @db.Decimal(12, 2)
  status           MeterStatus       @default(ACTIVE)
  parentId         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  organization     Organization      @relation(fields: [organizationId], references: [id])
  apartment        Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  room             Room?             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  parent           Meter?            @relation("MeterHierarchy", fields: [parentId], references: [id])
  subMeters        Meter[]           @relation("MeterHierarchy")
  readings         MeterReading[]
  billItemReadings BillItemReading[]

  @@index([organizationId, apartmentId])
  @@index([roomId, status])
}

model MeterReading {
  id               String             @id @default(cuid())
  organizationId   String
  apartmentId      String
  roomId           String
  leaseId          String?
  meterId          String?
  meterType        MeterType
  readingDate      DateTime
  value            Decimal            @db.Decimal(12, 2)
  usage            Decimal?           @db.Decimal(12, 2)
  source           MeterReadingSource @default(MANUAL)
  readType         MeterReadingType   @default(MANUAL)
  status           MeterReadingStatus @default(NORMAL)
  photoUrl         String?
  note             String?
  createdById      String?
  createdAt        DateTime           @default(now())
  deletedAt        DateTime?
  organization     Organization       @relation(fields: [organizationId], references: [id])
  apartment        Apartment          @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  room             Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  lease            Lease?             @relation(fields: [leaseId], references: [id])
  meter            Meter?             @relation(fields: [meterId], references: [id])
  createdBy        User?              @relation(fields: [createdById], references: [id])
  billItems        BillItem[]
  billItemReadings BillItemReading[]

  @@index([organizationId, roomId, meterType, readingDate])
  @@index([leaseId, meterType, readingDate])
  @@index([meterId, readingDate])
}

// ==================== 维修工单 ====================

model MaintenanceOrder {
  id             String                  @id @default(cuid())
  organizationId String
  apartmentId    String?
  roomId         String?
  type           MaintenanceOrderType
  priority       MaintenancePriority     @default(NORMAL)
  title          String
  description    String?
  reporterName   String?
  reporterPhone  String?
  scheduledDate  DateTime?
  completedDate  DateTime?
  materialCost   Decimal                 @default(0) @db.Decimal(12, 2)
  laborCost      Decimal                 @default(0) @db.Decimal(12, 2)
  totalCost      Decimal                 @default(0) @db.Decimal(12, 2)
  status         MaintenanceOrderStatus  @default(PENDING)
  assignedTo     String?
  acceptanceNote String?
  beforePhotoUrl String?
  afterPhotoUrl  String?
  isTenantFault  Boolean                 @default(false)
  billItemId     String?
  createdById    String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?
  organization   Organization            @relation(fields: [organizationId], references: [id])
  apartment      Apartment?              @relation(fields: [apartmentId], references: [id])
  room           Room?                   @relation(fields: [roomId], references: [id])
  createdBy      User?                   @relation(fields: [createdById], references: [id])
  items          MaintenanceOrderItem[]

  @@index([organizationId, status])
  @@index([roomId, status])
  @@index([priority, status])
}

model MaintenanceOrderItem {
  id                 String           @id @default(cuid())
  maintenanceOrderId String
  name               String
  quantity           Int              @default(1)
  unitPrice          Decimal          @default(0) @db.Decimal(12, 2)
  amount             Decimal          @default(0) @db.Decimal(12, 2)
  isLabor            Boolean          @default(false)
  deletedAt          DateTime?
  maintenanceOrder   MaintenanceOrder @relation(fields: [maintenanceOrderId], references: [id], onDelete: Cascade)

  @@index([maintenanceOrderId])
}

// ==================== 房间检查清单 ====================

model RoomChecklist {
  id             String            @id @default(cuid())
  organizationId String
  leaseId        String
  roomId         String
  checkType      RoomCheckType
  checkDate      DateTime
  checkedById    String?
  tenantSignUrl  String?
  operatorSignUrl String?
  note           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id])
  lease          Lease             @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  room           Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  items          RoomChecklistItem[]

  @@index([leaseId, checkType])
  @@index([roomId, checkType])
}

model RoomChecklistItem {
  id              String        @id @default(cuid())
  checklistId     String
  category        String        // 水电/门窗/墙面/家具/家电/卫生/钥匙/其他
  itemName        String
  status          String        // 完好/损坏/缺失/脏污
  description     String?
  photoUrl        String?
  deductionAmount Decimal?      @db.Decimal(12, 2)
  note            String?
  deletedAt       DateTime?
  roomChecklist   RoomChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

// ==================== 出纳与财务 ====================

model IncomeExpenseCategory {
  id             String           @id @default(cuid())
  organizationId String
  type           IncomeExpenseType
  code           String
  name           String
  parentId       String?
  sortOrder      Int              @default(0)
  isSystem       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         IncomeExpenseCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       IncomeExpenseCategory[] @relation("CategoryHierarchy")
  expenses       ApartmentExpense[]

  @@unique([organizationId, code])
  @@index([organizationId, type])
}

model CashierJournal {
  id              String           @id @default(cuid())
  organizationId  String
  date            DateTime
  type            IncomeExpenseType
  categoryId      String?
  amount          Decimal          @db.Decimal(12, 2)
  paymentMethod   String
  accountType     CashierAccountType @default(CASH)
  counterparty    String?          // 对方名称
  counterpartyId  String?          // 租客ID/房东ID等
  relatedDocType  String?          // BILL / DEPOSIT / SETTLEMENT / CONTRACT / MAINTENANCE / OTHER
  relatedDocId    String?          // 关联单据ID
  relatedPaymentId String?         // 关联Payment ID
  summary         String
  operatorId      String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id])
  operator        User             @relation(fields: [operatorId], references: [id])

  @@index([organizationId, date])
  @@index([organizationId, type, date])
  @@index([counterpartyId, date])
  @@index([relatedDocType, relatedDocId])
}

// ==================== 租客账户 ====================

model TenantAccount {
  id             String               @id @default(cuid())
  tenantId       String               @unique
  prepaidBalance Decimal              @default(0) @db.Decimal(12, 2)
  depositBalance Decimal              @default(0) @db.Decimal(12, 2)
  totalUnpaid    Decimal              @default(0) @db.Decimal(12, 2)
  netBalance     Decimal              @default(0) @db.Decimal(12, 2)
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions   AccountTransaction[]
}

model AccountTransaction {
  id              String                  @id @default(cuid())
  tenantAccountId String
  type            AccountTransactionType
  amount          Decimal                 @db.Decimal(12, 2)
  balanceAfter    Decimal                 @db.Decimal(12, 2)
  referenceType   AccountReferenceType?
  referenceId     String?
  note            String?
  createdById     String?
  createdAt       DateTime                @default(now())
  tenantAccount   TenantAccount           @relation(fields: [tenantAccountId], references: [id], onDelete: Cascade)

  @@index([tenantAccountId, createdAt])
}

// ==================== 账单队列 ====================

model BillQueue {
  id           String          @id @default(cuid())
  leaseId      String          @unique
  nextBillDate DateTime
  lastBillDate DateTime?
  lastBillId   String?
  status       BillQueueStatus @default(PENDING)
  errorMsg     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lease        Lease           @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([nextBillDate, status])
}

// ==================== SaaS 运营 ====================

model Plan {
  id             String         @id @default(cuid())
  name           String
  apartmentLimit Int
  roomLimit      Int
  memberLimit    Int
  price          Decimal        @db.Decimal(12, 2)
  enabled        Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String
  planId         String
  startsAt       DateTime     @default(now())
  endsAt         DateTime?
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  plan           Plan         @relation(fields: [planId], references: [id])
}

model OrgQuotaPackage {
  id             String       @id @default(cuid())
  organizationId String
  apartmentQuota Int          @default(0)
  roomQuota      Int          @default(0)
  memberQuota    Int          @default(0)
  reason         String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
}

// ==================== 审计与系统 ====================

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String?
  tableName      String
  recordId       String
  action         String       // CREATE / UPDATE / DELETE / SOFT_DELETE / RESTORE
  fieldName      String?
  oldValue       String?
  newValue       String?
  userId         String
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId, tableName, recordId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  content        String
  link           String?
  readAt         DateTime?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, readAt])
  @@index([createdAt])
}

model Account {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  type           String
  bankName       String?
  accountNo      String?
  balance        Decimal           @default(0) @db.Decimal(12, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  outTransfers   AccountTransfer[] @relation("FromAccount")
  inTransfers    AccountTransfer[] @relation("ToAccount")

  @@index([organizationId])
}

model AccountTransfer {
  id              String       @id @default(cuid())
  organizationId  String
  fromAccountId   String
  toAccountId     String
  amount          Decimal      @db.Decimal(12, 2)
  note            String?
  createdById     String?
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromAccount     Account      @relation("FromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount       Account      @relation("ToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model Refund {
  id             String       @id @default(cuid())
  organizationId String
  tenantId       String
  type           RefundType
  amount         Decimal      @db.Decimal(12, 2)
  reason         String
  status         RefundStatus @default(PENDING)
  approverId     String?
  approvedAt     DateTime?
  note           String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approver       User?        @relation(fields: [approverId], references: [id])

  @@index([organizationId, status])
  @@index([tenantId])
}
