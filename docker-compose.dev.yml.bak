services:
  api:
    build:
      target: development
    command: sh -c "pnpm --filter @tenant-hub/api prisma generate && pnpm --filter @tenant-hub/api dev"
    environment:
      NODE_ENV: development
      CHOKIDAR_USEPOLLING: "true"
    volumes:
      - ./apps/api:/app/apps/api
      - /app/apps/api/node_modules

  ops-web:
    build:
      target: development
    command: pnpm --filter @tenant-hub/ops-web dev
    environment:
      NODE_ENV: development
      CHOKIDAR_USEPOLLING: "true"
      VITE_API_BASE_URL: http://localhost:4000/api
    ports: !override
      - "5173:5173"
    volumes:
      - ./apps/ops-web:/app/apps/ops-web
      - /app/apps/ops-web/node_modules

